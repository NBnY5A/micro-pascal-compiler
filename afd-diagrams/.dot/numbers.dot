digraph AFD_Numeros {
    rankdir=LR;
    node [shape=circle, fontname="Courier", fontsize=10];
    
    label="\"AFD para identificação de Números Inteiros e Reais\"";
    labelloc="t"

    qi [shape=point];
    
    q0 [label="q0 (Inicial)"];
    q2 [label="q2 (Inteiro)"];
    q3 [label="q3 (Real)"];
    q_acc_int [label="q_acc_int\n(Emitir INTEIRO)", shape=doublecircle];
    q_acc_real [label="q_acc_real\n(Emitir REAL)", shape=doublecircle];
    
    
    q_err_id [label="ERRO\nINVALID_IDENTIFIER", shape=doublecircle, color="red", style=filled, fillcolor="#ffe6e6"];
    q_err_num [label="ERRO\nINVALID_NUMBER", shape=doublecircle, color="red", style=filled, fillcolor="#ffe6e6"];
    
    
    qi -> q0;
    q0 -> q2 [label="[0-9]"];
    q2 -> q2 [label="[0-9]"];
    q2 -> q3 [label="'.'"];
    q2 -> q_err_id [label="[a-zA-Z_]"];
    q2 -> q_acc_int [label="';'"];
    
    q3 -> q3 [label="[0-9]"];
    q3 -> q_err_num [label="[a-zA-Z_]"];
    q3 -> q_acc_real [label="';'"];
}