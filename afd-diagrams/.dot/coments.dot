digraph AFD_Comentarios {
    rankdir=LR;
    node [shape=circle, fontname="Courier", fontsize=10];

    label="\"AFD para identificação de Comentários\"";
    labelloc="t"

    qi [shape=point];

    q0 [label="q0 (Inicial)"];
    q7 [label="q7 (Comentário)"];
    q_acc [label="q_acc\n(Descartar, volta p/ q0)", shape=doublecircle];
    
    q_err_eof [label="ERRO\nUNCLOSED_COMMENT", shape=doublecircle, color="red", style=filled, fillcolor="#ffe6e6"];
    
    qi -> q0
    q0 -> q7 [label="'{'"];
    q7 -> q7 [label="[^}]"];
    q7 -> q_acc [label="'}'"];
    q7 -> q_err_eof [label="EOF"];
}