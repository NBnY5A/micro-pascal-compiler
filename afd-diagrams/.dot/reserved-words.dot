digraph AFD_Identificadores {
    rankdir=LR;
    node [shape=circle, fontname="Courier", fontsize=10];
    
    label="\"AFD para Palavras Reservadas\"";
    labelloc="t"

    qi [shape=point];

    q0 [label="q0 (Inicial)", shape=circle];
    q1 [label="q1 (Id)", shape=circle];
    q_acc [label="q_acc\n(Emitir ID/Reservada)", shape=doublecircle];
    
    qi -> q0;
    q0 -> q1 [label="[a-zA-Z_]"];
    q1 -> q1 [label="[a-zA-Z0-9_]"];
    q1 -> q_acc [label="';'\n(Verifica próximo caractere)"];
}